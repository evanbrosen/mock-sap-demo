{
  "name": "mock-sap-demo",
  "version": "1.0.0",
  "description": "Mock SAP S/4HANA frontend with Fiori intent-based navigation and OData API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.backend.json && vite build",
    "start": "node dist/server.js",
    "dev": "npm run build:backend && concurrently \"node dist/server.js\" \"vite\"",
    "dev:server": "npm run build:backend && node dist/server.js",
    "dev:client": "vite",
    "build:backend": "tsc -p tsconfig.backend.json",
    "watch": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "sap",
    "fiori",
    "odata",
    "mock",
    "demo"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "sqlite3": "^5.1.6",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@shadcn/ui": "^0.0.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/sqlite3": "^3.1.11",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "ts-node": "^10.9.2",
    "vite": "^8.0.3"
  },
  "engines": {
    "node": "18.x"
  }
}
