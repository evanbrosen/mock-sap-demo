{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/server.ts", "src/config/**/*", "src/controllers/**/*", "src/models/**/*", "src/routes/**/*", "src/middleware/**/*", "src/utils/**/*"],
  "exclude": ["node_modules", "dist", "src/**/*.tsx", "src/App.tsx", "src/main.tsx", "src/pages/**/*", "src/components/**/*", "src/context/**/*", "src/lib/**/*"]
}
